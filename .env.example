# Environment Variables Template
# Copy this file to .env and fill in your actual values

# Airflow Configuration
AIRFLOW_UID=50000
AIRFLOW_GID=50000

# SMTP Configuration for Email Notifications
AIRFLOW_SMTP_USER=your-email@gmail.com
AIRFLOW_SMTP_PASSWORD=your-app-specific-password
AIRFLOW_SMTP_MAIL_FROM=your-email@gmail.com

# OpenWeather API Key (for weather pipeline DAG)
OPENWEATHER_API_KEY=your-api-key-here

# Snowflake Configuration (optional - can also use credentials JSON file)
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_ACCOUNT=your_account_id
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema
